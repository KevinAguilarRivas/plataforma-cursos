# Copiar este archivo a ".env" en la raíz del proyecto y completar con los valores reales.
# docker-compose lee automáticamente el archivo .env.

# ---- AWS S3 (almacenamiento Cloud) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=

# ---- Azure AD B2C (IdaaS) — app registration del BACKEND (API) ----
AZURE_ISSUER_URI=https://tutenantb2c.b2clogin.com/<tenant-id>/v2.0/
AZURE_JWK_SET_URI=https://tutenantb2c.b2clogin.com/tutenantb2c.onmicrosoft.com/B2C_1_signupsignin/discovery/v2.0/keys

# ---- Oracle Cloud (Autonomous DB) ----
ORACLE_DB_URL=jdbc:oracle:thin:@//TU_HOST_ORACLE:1521/TU_SERVICE_NAME
ORACLE_DB_USER=ADMIN
ORACLE_DB_PASSWORD=

# ---- CORS: dominio/IP pública donde corre el frontend ----
# En la demo se puede dejar "*"; para producción usar el dominio exacto (http://IP-EC2)
CORS_ALLOWED_ORIGINS=*
